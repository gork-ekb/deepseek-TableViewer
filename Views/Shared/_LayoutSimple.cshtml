<!DOCTYPE html>
<html lang="ru">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TableViewer</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
            :root {
                --primary-dark: #373D6D;
                --primary-gray: #878787;
                --white: #FFFFFF;
            }

            body {
                background-color: var(--white);
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                margin: 0;
                padding: 0;
            }

            /* Только базовые стили для таблицы */
            .table th {
                background-color: var(--primary-dark) !important;
                color: var(--white);
            }

            .table-striped tbody tr:nth-of-type(odd) {
                background-color: rgba(55, 61, 109, 0.05);
            }

            .pagination .page-item.active .page-link {
                background-color: var(--primary-dark);
                border-color: var(--primary-dark);
            }

            a {
                color: var(--primary-dark);
                text-decoration: none;
            }

            a:hover {
                text-decoration: underline;
            }
    </style>
    <style>
        .table-responsive, .table, .table thead, .table tbody, .table tr, .table th, .table td { overflow: visible !important; }
        .dropdown-menu { position: absolute; z-index: 9999; min-width: 250px; }
        .dropdown-toggle::after { display: none; }
        .filter-active { background-color: #FFCD80 !important; transition: background-color 0.2s ease; }
        .sort-icon { margin-left: 5px; font-size: 0.8em; }
        .filter-icon { margin-left: 5px; font-size: 0.8em; color: #FFCD80; }
        th.filter-active-header { background-color: #FF9A00 !important; color: #000 !important; }
        th.filter-active-header .btn-outline-light { color: #000 !important; border-color: #000 !important; }
        @@media (max-width: 768px) { .dropdown-menu { position: fixed !important; top: 50% !important; left: 50% !important; transform: translate(-50%, -50%) !important; width: 90%; max-width: 300px; } }
    </style>
</head>

<body>
    <main role="main">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>