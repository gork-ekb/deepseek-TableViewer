@model IEnumerable<dynamic>

@{
    var viewConfig = ViewBag.ViewConfig as TableViewer.Models.ViewConfig;
    ViewData["Title"] = viewConfig?.Header;
    var columns = ViewBag.Columns as List<string>;
    var filters = ViewBag.Filters as Dictionary<string, string>;
    var currentSortColumn = ViewBag.SortColumn as string;
    var currentSortDirection = ViewBag.SortDirection as string;
}

<style>
    /* Разрешаем переполнение */
    .table-responsive,
    .table,
    .table thead,
    .table tbody,
    .table tr,
    .table th,
    .table td {
        overflow: visible !important;
    }

    /* Стили для выпадающего меню */
    .dropdown-menu {
        position: absolute;
        z-index: 9999;
        min-width: 250px;
    }

    .dropdown-toggle::after {
        display: none;
    }

    /* Подсветка полей с фильтром */
    .filter-active {
        background-color: #FFCD80 !important;
        transition: background-color 0.2s ease;
    }

    /* Иконки сортировки */
    .sort-icon {
        margin-left: 5px;
        font-size: 0.8em;
    }

    /* Иконка фильтра */
    .filter-icon {
        margin-left: 5px;
        font-size: 0.8em;
        color: #FFCD80;
    }

    /* Заголовок с активным фильтром - НОВЫЙ ЦВЕТ #FF9A00 */
    th.filter-active-header {
        background-color: #FF9A00 !important;
        color: #000 !important;
    }

    th.filter-active-header .btn-outline-light {
        color: #000 !important;
        border-color: #000 !important;
    }

    /* Адаптация для маленьких экранов */
    @@media (max-width: 768px) {
        .dropdown-menu {
            position: fixed !important;
            top: 50% !important;
            left: 50% !important;
            transform: translate(-50%, -50%) !important;
            width: 90%;
            max-width: 300px;
        }
    }
</style>

<div class="container-fluid mt-2">
    @if (Model != null && Model.Any())
    {
        <div class="table-responsive" style="overflow-x: auto; overflow-y: visible;">
            <table class="table table-striped table-bordered table-hover" style="overflow: visible;">
                <thead class="table-dark">
                    <tr>
                        @foreach (var column in columns ?? new List<string>())
                        {
                            // Проверяем, есть ли фильтр для этой колонки
                            bool hasFilter = filters != null && filters.ContainsKey(column) &&
                    !string.IsNullOrEmpty(filters[column]);
                            // Проверяем, активна ли сортировка для этой колонки
                            bool isSorted = currentSortColumn == column;

                            <th style="min-width: 150px; position: relative;"
                                class="@(hasFilter ? "filter-active-header" : "")">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <span>@column</span>
                                        @if (isSorted)
                                        {
                                            if (currentSortDirection == "ASC")
                                            {
                                                <span class="sort-icon">▲</span>
                                            }
                                            else
                                            {
                                                <span class="sort-icon">▼</span>
                                            }
                                        }
                                        @if (hasFilter)
                                        {
                                            <span class="filter-icon" title="Фильтр активен: @filters[column]">
                                                🔍
                                            </span>
                                        }
                                    </div>
                                    <div class="dropdown" style="position: static;">
                                        <button class="btn btn-sm btn-outline-light dropdown-toggle" type="button"
                                                data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false"
                                                style="padding: 2px 8px;">
                                            <i class="bi bi-three-dots-vertical"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end" style="position: absolute; z-index: 9999;">
                                            <!-- Сортировка -->
                                            @if (viewConfig?.AllowSorting == true)
                                            {
                                                <li class="mb-2">
                                                    <h6 class="dropdown-header">Сортировка</h6>
                                                </li>
                                                <li>
                                                    <a class="dropdown-item @(currentSortColumn == column && currentSortDirection == "ASC" ? "active" : "")"
                                                           href="?sortColumn=@column&sortDirection=ASC&@(string.Join("&", filters?.Select(f => $"{f.Key}={f.Value}") ?? Array.Empty<string>()))">
                                                        <i class="bi bi-arrow-up"></i> По возрастанию
                                                        @if (currentSortColumn == column && currentSortDirection == "ASC")
                                                        {
                                                            <span class="float-end">✓</span>
                                                        }
                                                    </a>
                                                </li>
                                                <li class="mb-2">
                                                    <a class="dropdown-item @(currentSortColumn == column && currentSortDirection == "DESC" ? "active" : "")"
                                                           href="?sortColumn=@column&sortDirection=DESC&@(string.Join("&", filters?.Select(f => $"{f.Key}={f.Value}") ?? Array.Empty<string>()))">
                                                        <i class="bi bi-arrow-down"></i> По убыванию
                                                        @if (currentSortColumn == column && currentSortDirection == "DESC")
                                                        {
                                                            <span class="float-end">✓</span>
                                                        }
                                                    </a>
                                                </li>
                                                <li>
                                                    <a class="dropdown-item"
                                                           href="?@(string.Join("&", filters?.Select(f => $"{f.Key}={f.Value}") ?? Array.Empty<string>()))">
                                                        <i class="bi bi-x"></i> Сбросить сортировку
                                                    </a>
                                                </li>
                                            }

                                            <!-- Фильтрация -->
                                            @if (viewConfig?.AllowFiltering == true)
                                            {
                                                <li>
                                                    <hr class="dropdown-divider">
                                                </li>
                                                <li>
                                                    <h6 class="dropdown-header">Фильтрация</h6>
                                                </li>
                                                <li>
                                                    <form method="get" class="px-2 py-1" id="filterForm-@column">
                                                        <div class="mb-2">
                                                            <input type="text" name="@column" class="form-control form-control-sm"
                                                                   placeholder="Введите значение..."
                                                                   value="@(filters?.ContainsKey(column) == true ? filters[column] : "")"
                                                                   id="filterInput-@column" />
                                                        </div>
                                                        <div class="d-flex gap-2">
                                                            <button type="submit" class="btn btn-primary btn-sm w-100">
                                                                <i class="bi bi-search"></i> Применить
                                                            </button>
                                                            @if (hasFilter)
                                                            {
                                                                // Создаем URL без фильтра для этой колонки
                                                                var newFilters = filters?.Where(f => f.Key != column).ToDictionary(f =>
                                                f.Key, f => f.Value);
                                                                var filterUrl = "?" + string.Join("&", newFilters?.Select(f =>
                                                $"{f.Key}={f.Value}") ?? Array.Empty<string>());
                                                                if (!string.IsNullOrEmpty(currentSortColumn))
                                                                {
                                                                    filterUrl += (newFilters?.Any() == true ? "&" : "") +
                                                $"sortColumn={currentSortColumn}&sortDirection={currentSortDirection}";
                                                                }
                                                                <a href="@filterUrl" class="btn btn-secondary btn-sm w-100">
                                                                    <i class="bi bi-x"></i> Сброс
                                                                </a>
                                                            }
                                                        </div>
                                                    </form>
                                                </li>
                                            }
                                        </ul>
                                    </div>
                                </div>
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            @foreach (var column in columns ?? new List<string>())
                            {
                                // Подсветка ячейки, если по этой колонке есть фильтр
                                bool hasFilter = filters != null && filters.ContainsKey(column) &&
                    !string.IsNullOrEmpty(filters[column]);
                                var dict = item as IDictionary<string, object>;
                                var value = dict != null && dict.ContainsKey(column) ? dict[column] : null;

                                <td class="@(hasFilter ? "filter-active" : "")">
                                    @value
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
            <div class="text-muted mt-2">
                <small>Всего записей: @Model.Count()</small>
                @if (filters != null && filters.Any(f => !string.IsNullOrEmpty(f.Value)))
                {
                    <span class="ms-3">
                        <strong>Активные фильтры:</strong>
                        @foreach (var filter in filters.Where(f => !string.IsNullOrEmpty(f.Value)))
                        {
                            <span class="badge bg-warning text-dark ms-1">
                                @filter.Key = "@filter.Value"
                                @{
                                    var newFilters = filters.Where(f => f.Key != filter.Key).ToDictionary(f => f.Key, f => f.Value);
                                    var clearUrl = "?" + string.Join("&", newFilters.Select(f => $"{f.Key}={f.Value}"));
                                    if (!string.IsNullOrEmpty(currentSortColumn))
                                    {
                                        clearUrl += (newFilters.Any() ? "&" : "") +
                    $"sortColumn={currentSortColumn}&sortDirection={currentSortDirection}";
                                    }
                                }
                                <a href="@clearUrl" style="text-decoration: none; color: inherit;">✖</a>
                            </span>
                        }
                        <a href="?@(string.IsNullOrEmpty(currentSortColumn) ? "" : $"sortColumn={currentSortColumn}&sortDirection={currentSortDirection}")"
                           class="ms-2">Очистить все</a>
                    </span>
                }
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-warning text-center">
            <i class="bi bi-exclamation-triangle"></i> Нет данных для отображения
        </div>
    }
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        // Подсветка заголовка таблицы при активном фильтре
        const filterInputs = document.querySelectorAll('[id^="filterInput-"]');
        filterInputs.forEach(input => {
            if (input.value) {
                const th = input.closest('th');
                if (th) {
                    th.style.backgroundColor = '#FF9A00';  // Изменено с #FFCD80 на #FF9A00
                    th.style.color = '#000';
                }
            }
        });
    });
</script>