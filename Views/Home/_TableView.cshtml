@model IEnumerable<dynamic>

@{
    var viewConfig = ViewBag.ViewConfig as TableViewer.Models.ViewConfig;
    var columns = ViewBag.Columns as List<string>;
    var filters = ViewBag.Filters as Dictionary<string, string>;
    var currentSortColumn = ViewBag.SortColumn as string;
    var currentSortDirection = ViewBag.SortDirection as string;
    var isSimpleMode = viewConfig?.IsSimple ?? false;
}

<div class="table-responsive" style="overflow-x: auto; overflow-y: visible;">
    <table class="table table-striped table-bordered table-hover" style="overflow: visible;">
        <thead class="table-dark">
            <tr>
                @foreach (var column in columns ?? new List<string>())
                {
                    bool hasFilter = filters != null && filters.ContainsKey(column) && !string.IsNullOrEmpty(filters[column]);
                    bool isSorted = currentSortColumn == column;

                    <th style="min-width: 150px; position: relative;" class="@(hasFilter ? "filter-active-header" : "")">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <span>@column</span>
                                @if (isSorted)
                                {
                                    if (currentSortDirection == "ASC")
                                    {
                                        <span class="sort-icon">▲</span>
                                    }
                                    else
                                    {
                                        <span class="sort-icon">▼</span>
                                    }
                                }
                                @if (hasFilter)
                                {
                                    <span class="filter-icon" title="Фильтр активен: @filters[column]">🔍</span>
                                }
                            </div>
                            @if (!isSimpleMode)
                            {
                                <div class="dropdown" style="position: static;">
                                    <button class="btn btn-sm btn-outline-light dropdown-toggle"
                                            type="button"
                                            data-bs-toggle="dropdown"
                                            aria-expanded="false"
                                            style="padding: 2px 8px;">
                                        <i class="bi bi-three-dots-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        @if (viewConfig?.AllowSorting == true)
                                        {
                                            <li><h6 class="dropdown-header">Сортировка</h6></li>
                                            <li><a class="dropdown-item" href="?sortColumn=@column&sortDirection=ASC&@(string.Join("&", filters?.Select(f => $"{f.Key}={f.Value}") ?? Array.Empty<string>()))">
                                                <i class="bi bi-arrow-up"></i> По возрастанию</a></li>
                                            <li><a class="dropdown-item" href="?sortColumn=@column&sortDirection=DESC&@(string.Join("&", filters?.Select(f => $"{f.Key}={f.Value}") ?? Array.Empty<string>()))">
                                                <i class="bi bi-arrow-down"></i> По убыванию</a></li>
                                            <li><hr class="dropdown-divider"></li>
                                        }
                                        @if (viewConfig?.AllowFiltering == true)
                                        {
                                            <li><h6 class="dropdown-header">Фильтрация</h6></li>
                                            <li>
                                                <form method="get" class="px-2 py-1">
                                                    <div class="mb-2">
                                                        <input type="text" name="@column" class="form-control form-control-sm"
                                                               placeholder="Введите значение..."
                                                               value="@(filters?.ContainsKey(column) == true ? filters[column] : "")" />
                                                    </div>
                                                    <button type="submit" class="btn btn-primary btn-sm w-100">Применить</button>
                                                </form>
                                            </li>
                                        }
                                    </ul>
                                </div>
                            }
                        </div>
                    </th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    @foreach (var column in columns ?? new List<string>())
                    {
                        bool hasFilter = filters != null && filters.ContainsKey(column) && !string.IsNullOrEmpty(filters[column]);
                        var dict = item as IDictionary<string, object>;
                        var value = dict != null && dict.ContainsKey(column) ? dict[column] : null;
                        <td class="@(hasFilter ? "filter-active" : "")">@value</td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>